---
import { Picture } from "astro:assets";

import banner_stars from "../../assets/icons/strs_grp.png";

import slide1 from "../../assets/images/bnnr_sldr_card_1.png";
import slide2 from "../../assets/images/bnnr_sldr_card_2.png";
import slide3 from "../../assets/images/bnnr_sldr_card_3.png";

const slides = [
  { image: slide1, text: "book 1" },
  { image: slide2, text: "book 2" },
  { image: slide3, text: "book 3" },
];
---

<div class="banner-slider-wrap">
  <div class="swiper banner_card_slider">
    <div class="swiper-wrapper">
      {
        slides.map((slide) => (
          <div class="swiper-slide">
            <div class="slide-card">
              <Picture
                src={slide.image}
                alt={slide.text}
                formats={["avif", "webp"]}
                widths={[450]}
                sizes="450px"
                loading="eager"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div class="bnnr_strs">
    <Picture
      src={banner_stars}
      alt="stars group"
      formats={["avif", "webp"]}
      loading="eager"
    />
  </div>
</div>

<script>
  async function initBannerSlider() {
    // ✅ Load from public folder - no CDN needed
    await new Promise<void>((resolve) => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'swiper/swiper.min.css';
      link.onload = () => resolve();
      document.head.appendChild(link);
    });

    const [{ default: Swiper }, { EffectCards }] = await Promise.all([
      import("swiper"),
      import("swiper/modules"),
    ]);

    new Swiper(".banner_card_slider", {
      modules: [EffectCards],
      effect: "cards",
      grabCursor: true,
      loop: false,
      speed: 600,
      cardsEffect: {
        perSlideOffset: 8,
        perSlideRotate: 6,
        slideShadows: false,
      },
    });
  }

  window.addEventListener("load", initBannerSlider);
</script>

<style is:global>
      .bnnr_sldr_wrp{
      flex-grow: 1;
      align-self: flex-end;
    }
    .banner_card_slider{
        width: 450px;
    }
    .slide-card a{
      display: block;
    }
    .slide-card a img{
      width: 100%;
    }

    .banner-slider-wrap{
      position: relative;
    }
    .banner_card_slider  .swiper-slide:not(.swiper-slide-active) .slide-card{
      filter: blur(5px);
      pointer-events: none;
    }
    .bnnr_strs {
        position: absolute;
        top: -150px;
        left: 20px;
    }

        /* ── Responsive ──────────────────────────────────────────────── */
    @media (max-width: 1900px) {

      .banner_card_slider {
          width: 320px;
          margin-bottom: 60px;
      }
      .bnnr_strs {
          position: absolute;
          top: -60px;
          left: -30px;
          right: -30px;
      }

    }
    @media (max-width: 767px) {
    .banner_card_slider {
      margin-bottom: 0;
      width: 240px;
    }
    .bnnr_strs {
      top: -40px;
      left: 0;
      right: 0;
      bottom: 0;
      max-width: 460px;
      margin: 0 auto;
    }
    }

</style>