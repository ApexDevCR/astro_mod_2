<script>
  async function initBannerSlider() {
    // Load CSS synchronously if not already present
    if (!document.querySelector('link[href="swiper/swiper.min.css"]')) {
      await new Promise<void>((resolve) => {
        const link = document.createElement("link");
        link.rel = "stylesheet";
        link.href = "swiper/swiper.min.css";
        link.onload = () => resolve();
        link.onerror = () => resolve();
        document.head.appendChild(link);
      });
    }
 
    const [{ default: Swiper }, { EffectCards }] = await Promise.all([
      import("swiper"),
      import("swiper/modules"),
    ]);
 
    new Swiper(".banner_card_slider", {
      modules: [EffectCards],
      effect: "cards",
      grabCursor: true,
      loop: false,
      // Slightly longer speed to reduce GPU burst on mobile
      speed: 450,
      cardsEffect: {
        perSlideOffset: 8,
        perSlideRotate: 6,
        slideShadows: false,
      },
    });
  }
 
  // Use DOMContentLoaded instead of load so slider appears sooner,
  // but only after the DOM is ready (avoids flash on slow connections)
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBannerSlider);
  } else {
    initBannerSlider();
  }
</script>
 
